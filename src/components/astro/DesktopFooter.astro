---
import { profile } from '../../data/profile';
import SocialLinks from './SocialLinks.astro';

const year = new Date().getFullYear();
---

<footer class="desktop-footer">
  <p>© The Naeem Edition {year}</p>
  <p>{profile.location}</p>
  <SocialLinks compact />
  <a href="#about" data-chapter-link="about">Credits</a>
</footer>

<style>
  .desktop-footer {
    display: none;
  }

  @media (min-width: 64rem) {
    .desktop-footer {
      position: fixed;
      inset: auto 0 0;
      z-index: 40;
      display: grid;
      grid-template-columns: 1.2fr 1fr 1.25fr 0.55fr;
      align-items: center;
      height: var(--footer-height);
      border-top: 1px solid var(--color-rule);
      background: rgb(242 239 231 / 97%);
      font-size: 0.67rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .desktop-footer > :global(*) {
      display: flex;
      align-items: center;
      height: 100%;
      padding-inline: clamp(1rem, 2.2vw, 2rem);
      border-right: 1px solid var(--color-rule);
    }

    .desktop-footer > :global(*:last-child) {
      border-right: 0;
    }
  }
</style>
