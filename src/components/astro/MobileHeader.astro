---
import { profile } from '../../data/profile';
---

<header class="mobile-header">
  <div>
    <a class="mobile-name" href="#introduction">{profile.name}</a>
    <p>{profile.professionalTitle} · CMS · E-commerce</p>
  </div>
  <button type="button" data-index-trigger aria-haspopup="dialog" aria-controls="portfolio-index-dialog">
    Menu
  </button>
</header>

<style>
  .mobile-header {
    position: sticky;
    top: 0;
    z-index: 50;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    min-height: 5.5rem;
    padding: 1.1rem var(--page-padding) 0.85rem;
    border-bottom: 1px solid var(--color-rule);
    background: rgb(242 239 231 / 96%);
  }

  .mobile-name,
  button {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mobile-header > div {
    min-width: 0;
  }

  .mobile-name {
    text-decoration: none;
  }

  p {
    max-width: 100%;
    overflow-wrap: anywhere;
    margin-top: 0.4rem;
    color: var(--color-ink-muted);
    font-size: 0.61rem;
    letter-spacing: 0.06em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  button {
    flex: 0 0 auto;
    min-width: 3.75rem;
    min-height: 2.75rem;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  @media (min-width: 64rem) {
    .mobile-header {
      display: none;
    }
  }
</style>
