---
interface Props {
  id: string;
  numeral: string;
  title: string;
  kicker?: string;
}

const { id, numeral, title, kicker } = Astro.props;
---

<header class="section-heading">
  <p class="eyebrow">Part {numeral}</p>
  <h2 id={`heading-${id}`} class="chapter-title" tabindex="-1">{title}</h2>
  {kicker && <p class="section-kicker">{kicker}</p>}
</header>

<style>
  .section-heading {
    display: grid;
    gap: 0.8rem;
    padding-bottom: clamp(1.5rem, 3vw, 2.5rem);
    border-bottom: 1px solid var(--color-rule);
  }

  .section-kicker {
    max-width: 52rem;
    color: var(--color-ink-muted);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    line-height: 1.6;
    text-transform: uppercase;
  }
</style>
