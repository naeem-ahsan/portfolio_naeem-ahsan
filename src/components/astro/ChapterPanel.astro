---
import type { NavigationItem } from '../../data/types';

interface Props {
  item: NavigationItem;
}

const { item } = Astro.props;
const panelId = `chapter-panel-${item.id}`;
const tabId = `chapter-tab-${item.id}`;
---

<section
  id={item.id}
  class="chapter-panel"
  data-chapter={item.id}
  data-active={item.id === 'introduction' ? 'true' : 'false'}
  aria-labelledby={`heading-${item.id}`}
>
  <button
    id={tabId}
    class="chapter-tab"
    type="button"
    data-chapter-tab={item.id}
    aria-controls={panelId}
    aria-expanded={item.id === 'introduction' ? 'true' : 'false'}
  >
    <span>Part {item.numeral} — {item.label}</span>
  </button>

  <div id={panelId} class="chapter-content" data-chapter-content>
    <slot />
  </div>
</section>
