---
import SectionHeading from '../components/astro/SectionHeading.astro';
import { skillGroups } from '../data/skills';
---

<SectionHeading id="skills" numeral="IV" title="Classifieds & Skills" kicker="A technical directory of tools and platforms" />

<div class="skills-grid">
  {skillGroups.map((group, index) => (
    <section class="skill-group" aria-labelledby={`skill-group-${index}`}>
      <p class="classified-label">Section {String(index + 1).padStart(2, '0')}</p>
      <h3 id={`skill-group-${index}`}>{group.title}</h3>
      <ul>
        {group.skills.map((skill) => <li>{skill}</li>)}
      </ul>
    </section>
  ))}
</div>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 13rem), 1fr));
    border-left: 1px solid var(--color-rule);
  }

  .skill-group {
    min-height: 17rem;
    padding: 1.5rem;
    border-right: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
  }

  .classified-label {
    color: var(--color-accent-dark);
    font-size: 0.67rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h3 {
    margin: 2.5rem 0 1.25rem;
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 400;
    text-transform: uppercase;
  }

  ul { display: grid; gap: 0.5rem; list-style: none; }
  li { font-size: 0.82rem; }
</style>
