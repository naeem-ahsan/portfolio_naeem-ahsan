---
import '../styles/global.css';
import '../styles/chapters.css';
import { profile } from '../data/profile';
import { skillGroups } from '../data/skills';
import { socialLinks } from '../data/socialLinks';

interface Props {
  title: string;
  description: string;
  image?: string;
}

const {
  title,
  description,
  image = '/og/portfolio-placeholder.svg',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://example.com');
const approvedSameAs = socialLinks
  .filter((link) => link.external && !link.placeholder)
  .map((link) => link.href);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name,
  jobTitle: profile.professionalTitle,
  email: profile.email,
  telephone: profile.phone,
  url: canonical.origin,
  homeLocation: {
    '@type': 'Place',
    name: profile.location,
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Kuala Lumpur',
      addressCountry: 'MY',
    },
  },
  knowsAbout: skillGroups.flatMap((group) => group.skills),
  ...(approvedSameAs.length > 0 ? { sameAs: approvedSameAs } : {}),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f2efe7" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, canonical)} />
    <meta property="og:image:alt" content="Naeem Ahsan — Web Application Developer" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, canonical)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to portfolio content</a>
    <slot />
  </body>
</html>
